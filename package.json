{
  "name": "obsidian-3d-graph-view",
  "version": "0.1.1",
  "description": "An Obsidian plugin that renders a rotatable 3D graph view.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "graph",
    "3d"
  ],
  "author": "Steve",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/three": "^0.184.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "d3-force-3d": "^3.0.6",
    "three": "^0.162.0"
  }
}
